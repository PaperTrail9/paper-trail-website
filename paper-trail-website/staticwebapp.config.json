{
  "$schema": "https://json.schemastore.org/staticwebapp.config.json",
  "routes": [
    {
      "route": "/",
      "rewrite": "/index.html"
    },
    {
      "route": "/blog",
      "rewrite": "/blog/index.html"
    },
    {
      "route": "/blog/",
      "rewrite": "/blog/index.html"
    },
    {
      "route": "/apps/reel-reviews",
      "rewrite": "/apps/reel-reviews/index.html"
    },
    {
      "route": "/apps/reel-reviews/",
      "rewrite": "/apps/reel-reviews/index.html"
    },
    {
      "route": "/apps/coming-soon",
      "rewrite": "/apps/coming-soon/index.html"
    },
    {
      "route": "/apps/coming-soon/",
      "rewrite": "/apps/coming-soon/index.html"
    },
    {
      "route": "/contact",
      "rewrite": "/contact.html"
    },
    {
      "route": "/contact/",
      "rewrite": "/contact.html"
    },
    {
      "route": "/privacy-policy",
      "rewrite": "/privacy-policy.html"
    },
    {
      "route": "/terms-of-service",
      "rewrite": "/terms-of-service.html"
    }
  ],
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": [
      "/assets/*",
      "/css/*", 
      "/js/*",
      "/blog/posts/*",
      "*.css",
      "*.js",
      "*.png",
      "*.jpg",
      "*.svg",
      "*.html"
    ]
  },
  "responseOverrides": {
    "404": {
      "rewrite": "/index.html"
    }
  },
  "globalHeaders": {
    "content-security-policy": "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data:; connect-src 'self';",
    "X-Frame-Options": "DENY",
    "X-Content-Type-Options": "nosniff",
    "Referrer-Policy": "strict-origin-when-cross-origin"
  },
  "mimeTypes": {
    ".json": "text/json"
  }
}
